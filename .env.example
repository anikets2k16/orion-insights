# ── Determinism (NFR-1) ──
ORION_DETERMINISTIC=true
ORION_LLM_CACHE_MODE=read_write     # read_write | read_only | refresh
ORION_LLM_SEED=42

# ── Execution backends ──
ORION_TASK_BACKEND=background       # background | celery
ORION_SESSION_BACKEND=memory        # memory | redis  (use redis with celery)

# ── LLM APIs (real LLMs required — NFR-2) ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
SERPAPI_KEY=

# ── Database / cache ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
DATABASE_URL=postgresql://orion:orion_dev@localhost:5432/orion
POSTGRES_PASSWORD=orion_dev
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars

# ── Integrations (optional) ──
GITHUB_TOKEN=
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_TOKEN=

# ── Observability (optional) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Frontend → Python backend bridge ──
# Deployed FastAPI URL (see render.yaml). Used by src/lib/orion-api.ts.
VITE_ORION_API_URL=https://orion-api-xxxx.onrender.com
